  # @see RightBiased::Left#value_or
  #
  # pkg:gem/dry-monads#lib/dry/monads/result.rb:236
  def value_or(val = T.unsafe(nil)); end

  class << self
    # Shortcut for Failure([...])
    #
    #  @example
    #    include Dry::Monads[:result]
    #
    #    def call
    #      Failure[:error, :not_found] # => Failure([:error, :not_found])
    #    end
    #
    # @api public
    #
    # pkg:gem/dry-monads#lib/dry/monads/result.rb:151
    def [](*value); end

    # pkg:gem/dry-monads#lib/dry/monads/result.rb:139
    def call(*_arg0); end

    # Returns a constructor proc
    #
    # @return [Proc]
    #
    # pkg:gem/dry-monads#lib/dry/monads/result.rb:158
    def to_proc; end
  end
end

# @see Monads#Result
# @private
#
# pkg:gem/dry-monads#lib/dry/monads/result/fixed.rb:10
class Dry::Monads::Result::Fixed < ::Module
  # pkg:gem/dry-monads#lib/dry/monads/result/fixed.rb:13
  def initialize(error, **_arg1); end

  private

  # pkg:gem/dry-monads#lib/dry/monads/result/fixed.rb:35
  def included(base); end

  class << self
    # pkg:gem/dry-monads#lib/dry/monads/result/fixed.rb:11
    def [](error, **options); end
  end
end

# A module that can be included for easier access to Result monads.
#
# @api public
#
# pkg:gem/dry-monads#lib/dry/monads/result.rb:279
module Dry::Monads::Result::Mixin
  include ::Dry::Monads::Result::Mixin::Constructors
end

# Value constructors
#
# pkg:gem/dry-monads#lib/dry/monads/result.rb:287
module Dry::Monads::Result::Mixin::Constructors
  # Failure constructor
  #
  # @overload Success(value)
  #   @param value [Object]
  #   @return [Result::Failure]
  #
  # @overload Success(&block)
  #   @param block [Proc] a block to be wrapped with Failure
  #   @return [Result::Failure]
  #
  # pkg:gem/dry-monads#lib/dry/monads/result.rb:313
  def Failure(value = T.unsafe(nil), &block); end

  # Success constructor
  #
  # @overload Success(value)
  #   @param value [Object]
  #   @return [Result::Success]
  #
  # @overload Success(&block)
  #   @param block [Proc] a block to be wrapped with Success
  #   @return [Result::Success]
  #
  # pkg:gem/dry-monads#lib/dry/monads/result.rb:298
  def Success(value = T.unsafe(nil), &block); end
end

# @see Result::Failure
#
# pkg:gem/dry-monads#lib/dry/monads/result.rb:283
Dry::Monads::Result::Mixin::Failure = Dry::Monads::Result::Failure

# @see Result::Success
#
# pkg:gem/dry-monads#lib/dry/monads/result.rb:281
Dry::Monads::Result::Mixin::Success = Dry::Monads::Result::Success

# Represents a value of a successful operation.
#
# @api public
#
# pkg:gem/dry-monads#lib/dry/monads/result.rb:53
class Dry::Monads::Result::Success < ::Dry::Monads::Result
  include ::Dry::Monads::RightBiased::Right
  include ::Dry::Core::Equalizer::Methods
  extend ::Dry::Core::Deprecations::Interface

  # @param value [Object] a value of a successful operation
  #
  # pkg:gem/dry-monads#lib/dry/monads/result.rb:72
  def initialize(value); end

  # Ignores values and returns self, see {Failure#alt_map}
  #
  # @return [Result::Success]
  #
  # pkg:gem/dry-monads#lib/dry/monads/result.rb:129
  def alt_map(_ = T.unsafe(nil), &_arg1); end

  # Returns result of applying first function to the internal value.
  #
  # @example
  #   Dry::Monads.Success(1).either(-> x { x + 1 }, -> x { x + 2 }) # => 2
  #
  # @param f [#call] Function to apply
  # @param _ [#call] Ignored
  # @return [Any] Return value of `f`
  #
  # pkg:gem/dry-monads#lib/dry/monads/result.rb:107
  def either(f, _); end

  # Returns false
  #
  # pkg:gem/dry-monads#lib/dry/monads/result.rb:83
  def failure?; end

  # Transforms to a Failure instance
  #
  # @return [Result::Failure]
  #
  # pkg:gem/dry-monads#lib/dry/monads/result.rb:122
  def flip; end

  # Does the same thing as #bind except it also wraps the value
  # in an instance of Result::Success monad. This allows for easier
  # chaining of calls.
  #
  # @example
  #   Dry::Monads.Success(4).fmap(&:succ).fmap(->(n) { n**2 }) # => Success(25)
  #
  # @param args [Array<Object>] arguments will be transparently passed through to #bind
  # @return [Result::Success]
  #
  # pkg:gem/dry-monads#lib/dry/monads/result.rb:97
  def fmap(*_arg0, **_arg1, &_arg2); end

  # pkg:gem/dry-monads#lib/dry/monads/result.rb:117
  def inspect; end

  # Apply the second function to value.
  #
  # @api public
  #
  # pkg:gem/dry-monads#lib/dry/monads/result.rb:80
  def result(_, f); end

  # pkg:gem/dry-monads#lib/dry/monads/result.rb:69
  def success; end

  # Returns true
  #
  # pkg:gem/dry-monads#lib/dry/monads/result.rb:86
  def success?; end

  # @return [Maybe]
  #
  # pkg:gem/dry-monads#lib/dry/monads/maybe.rb:362
  def to_maybe; end

  # @return [String]
  #
  # pkg:gem/dry-monads#lib/dry/monads/result.rb:110
  def to_s; end

  # Transforms to Validated
  #
  # @return [Validated::Valid]
  #
  # pkg:gem/dry-monads#lib/dry/monads/validated.rb:280
  def to_validated; end

  class << self
    # Shortcut for Success([...])
    #
    #  @example
    #    include Dry::Monads[:result]
    #
    #    def call
    #      Success[200, {}, ['ok']] # => Success([200, {}, ['ok']])
    #    end
    #
    # @api public
    #
    # pkg:gem/dry-monads#lib/dry/monads/result.rb:67
    def [](*value); end

    # pkg:gem/dry-monads#lib/dry/monads/result.rb:54
    def call(*_arg0); end

    # pkg:gem/dry-monads#lib/dry/monads/result.rb:54
    def to_proc; end
  end
end

# A common module for right-biased monads, such as Result/Either, Maybe, and Try.
#
# pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:6
module Dry::Monads::RightBiased; end

# Left/wrong/erroneous part
#
# @api public
#
# pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:237
module Dry::Monads::RightBiased::Left
  # Returns self back. It exists to keep the interface
  # identical to that of {RightBiased::Right}.
  #
  # @return [RightBiased::Left]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:322
  def and(_, &_arg1); end

  # Ignores the input parameter and returns self. It exists to keep the interface
  # identical to that of {RightBiased::Right}.
  #
  # @return [RightBiased::Left]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:304
  def apply(*_arg0, **_arg1, &_arg2); end

  # Ignores the input parameter and returns self. It exists to keep the interface
  # identical to that of {RightBiased::Right}.
  #
  # @return [RightBiased::Left]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:249
  def bind(*_arg0, **_arg1, &_arg2); end

  # Pattern matching
  #
  # @example
  #   case Success(x)
  #   in Success(Integer)
  #     # ...
  #   in Success(2..100)
  #     # ...
  #   in Success(2..200 => code)
  #     # ...
  #   in Failure(_)
  #     # ...
  #   end
  #
  # @api private
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:339
  def deconstruct; end

  # Pattern matching hash values
  #
  # @example
  #   case Failure(x)
  #   in Failure(code: 400...500) then :user_error
  #   in Failure(code: 500...600) then :server_error
  #   end
  #
  # @api private
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:358
  def deconstruct_keys(keys); end

  # Returns self back. It exists to keep the interface
  # identical to that of {RightBiased::Right}.
  #
  # @return [RightBiased::Left]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:310
  def discard; end

  # Returns self back. It exists to keep the interface
  # identical to that of {RightBiased::Right}.
  #
  # @return [RightBiased::Left]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:316
  def flatten; end

  # Ignores the input parameter and returns self. It exists to keep the interface
  # identical to that of {RightBiased::Right}.
  #
  # @return [RightBiased::Left]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:261
  def fmap(*_arg0, **_arg1, &_arg2); end

  # Left-biased #bind version.
  #
  # @example
  #   Dry::Monads.Left(ArgumentError.new('error message')).or(&:message) # => "error message"
  #   Dry::Monads.None.or('no value') # => "no value"
  #   Dry::Monads.None.or { Time.now } # => current time
  #
  # @return [Object]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:271
  def or(*_arg0, **_arg1, &_arg2); end

  # A lifted version of `#or`. This is basically `#or` + `#fmap`.
  #
  # @example
  #   Dry::Monads.None.or_fmap('no value') # => Some("no value")
  #   Dry::Monads.None.or_fmap { Time.now } # => Some(current time)
  #
  # @return [RightBiased::Left, RightBiased::Right]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:287
  def or_fmap(*_arg0, **_arg1, &_arg2); end

  # Ignores the input parameter and returns self. It exists to keep the interface
  # identical to that of {RightBiased::Right}.
  #
  # @return [RightBiased::Left]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:255
  def tee(*_arg0, **_arg1, &_arg2); end

  # Raises an error on accessing internal value
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:243
  def value!; end

  # Returns the passed value
  #
  # @return [Object]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:292
  def value_or(val = T.unsafe(nil)); end

  # Returns the passed value. Works in pair with {RightBiased::Right#|}.
  #
  # @param alt [RightBiased::Right, RightBiased::Left]
  #
  # @return [RightBiased::Right, RightBiased::Left]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:278
  def |(alt); end

  class << self
    # @private
    # @return [String] Caller location
    #
    # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:240
    def trace_caller; end
  end
end

# Right part
#
# @api public
#
# pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:10
module Dry::Monads::RightBiased::Right
  # @param other [Object]
  # @return [Boolean]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:122
  def ===(other); end

  # Combines the wrapped value with another monadic value.
  # If both values are right-sided, yields a block and passes a tuple
  # of values there. If no block given, returns a tuple of values wrapped with
  # a monadic structure.
  #
  # @example
  #   include Dry::Monads::Result::Mixin
  #
  #   Success(3).and(Success(5)) # => Success([3, 5])
  #   Success(3).and(Failure(:not_a_number)) # => Failure(:not_a_number)
  #   Failure(:not_a_number).and(Success(5)) # => Failure(:not_a_number)
  #   Success(3).and(Success(5)) { |a, b| a + b } # => Success(8)
  #
  # @param mb [RightBiased::Left,RightBiased::Right]
  #
  # @return [RightBiased::Left,RightBiased::Right]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:163
  def and(mb); end

  # Applies the stored value to the given argument if the argument has type of Right,
  # otherwise returns the argument.
  #
  # @example happy path
  #   create_user = Dry::Monads::Success(CreateUser.new)
  #   name = Success("John")
  #   create_user.apply(name) # equivalent to CreateUser.new.call("John")
  #
  # @example unhappy path
  #   name = Failure(:name_missing)
  #   create_user.apply(name) # => Failure(:name_missing)
  #
  # @return [RightBiased::Left,RightBiased::Right]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:112
  def apply(val = T.unsafe(nil), &block); end

  # Calls the passed in Proc object with value stored in self
  # and returns the result.
  #
  # If proc is nil, it expects a block to be given and will yield to it.
  #
  # @example
  #   Dry::Monads.Right(4).bind(&:succ) # => 5
  #
  # @param [Array<Object>] args arguments that will be passed to a block
  #                             if one was given, otherwise the first
  #                             value assumed to be a Proc (callable)
  #                             object and the rest of args will be passed
  #                             to this object along with the internal value
  # @return [Object] result of calling proc or block on the internal value
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:40
  def bind(*args, **kwargs); end

  # Pattern matching
  #
  # @example
  #   case Success(x)
  #   in Success(Integer)
  #     # ...
  #   in Success(2..100)
  #     # ...
  #   in Success(2..200 => code)
  #     # ...
  #   end
  #
  # @api private
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:188
  def deconstruct; end

  # Pattern matching hash values
  #
  # @example
  #   case Success(x)
  #   in Success(code: 200...300) then :ok
  #   in Success(code: 300...400) then :redirect
  #   in Success(code: 400...500) then :user_error
  #   in Success(code: 500...600) then :server_error
  #   end
  #
  # @api private
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:209
  def deconstruct_keys(keys); end

  # Maps the value to Dry::Monads::Unit, useful when you don't care
  # about the actual value.
  #
  # @example
  #   Dry::Monads::Success(:success).discard
  #   # => Success(Unit)
  #
  # @return [RightBiased::Right]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:134
  def discard; end

  # Removes one level of monad structure by joining two values.
  #
  # @example
  #   include Dry::Monads::Result::Mixin
  #   Success(Success(5)).flatten # => Success(5)
  #   Success(Failure(:not_a_number)).flatten # => Failure(:not_a_number)
  #   Failure(:not_a_number).flatten # => Failure(:not_a_number)
  #
  # @return [RightBiased::Right,RightBiased::Left]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:145
  def flatten; end

  # Abstract method for lifting a block over the monad type.
  # Must be implemented for a right-biased monad.
  #
  # @return [RightBiased::Right]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:72
  def fmap(*_arg0, **_arg1, &_arg2); end

  # Ignores arguments and returns self. It exists to keep the interface
  # identical to that of {RightBiased::Left}.
  #
  # @return [RightBiased::Right]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:78
  def or(*_arg0, **_arg1, &_arg2); end

  # A lifted version of `#or`. For {RightBiased::Right} acts in the same way as `#or`,
  # that is returns itselt.
  #
  # @return [RightBiased::Right]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:92
  def or_fmap(*_arg0, **_arg1, &_arg2); end

  # Does the same thing as #bind except it returns the original monad
  # when the result is a Right.
  #
  # @example
  #   Dry::Monads.Right(4).tee { Right('ok') } # => Right(4)
  #   Dry::Monads.Right(4).tee { Left('fail') } # => Left('fail')
  #
  # @param [Array<Object>] args arguments will be transparently passed through to #bind
  # @return [RightBiased::Right]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:66
  def tee(*_arg0, **_arg1, &_arg2); end

  # Unwraps the underlying value
  #
  # @return [Object]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:24
  def value!; end

  # Returns value. It exists to keep the interface identical to that of RightBiased::Left
  #
  # @return [Object]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:97
  def value_or(_val = T.unsafe(nil), &_arg1); end

  # Ignores arguments and returns self. It exists to keep the interface
  # identical to that of {RightBiased::Left}.
  #
  # @param _alt [RightBiased::Right, RightBiased::Left]
  #
  # @return [RightBiased::Right]
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:86
  def |(_alt); end

  private

  # @api private
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:229
  def curry; end

  # @api private
  #
  # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:220
  def destructure(value); end

  class << self
    # @private
    #
    # pkg:gem/dry-monads#lib/dry/monads/right_biased.rb:12
    def included(m); end
  end
end

# @see Maybe::Some
#
# pkg:gem/dry-monads#lib/dry/monads/maybe.rb:353
Dry::Monads::Some = Dry::Monads::Maybe::Some

# @see Result::Success
#
# pkg:gem/dry-monads#lib/dry/monads/result.rb:326
Dry::Monads::Success = Dry::Monads::Result::Success

# The Task monad represents an async computation. The implementation
# is a rather thin wrapper of Concurrent::Promise from the concurrent-ruby.
# The API supports setting a custom executor from concurrent-ruby.
#
# @api public
#
# pkg:gem/dry-monads#lib/dry/monads/task.rb:12
class Dry::Monads::Task
  extend ::Dry::Core::Deprecations::Interface

  # @api private
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:87
  def initialize(promise); end

  # Compares two tasks. Note, it works
  # good enough only for complete tasks.
  #
  # @return [Boolean]
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:191
  def ==(other); end

  # Applies the stored value to the given argument.
  #
  # @example
  #   Task.
  #     pure { |x, y| x ** y }.
  #     apply(Task { 2 }).
  #     apply(Task { 3 }).
  #     to_maybe # => Some(8)
  #
  # @param val [Task]
  # @return [Task]
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:222
  def apply(val = T.unsafe(nil), &_arg1); end

  # Composes two tasks to run one after another.
  # A more common name is `then` exists as an alias.
  #
  # @param block [Proc] A block that yields the result of the current task
  #                     and returns another task
  # @return [Task]
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:119
  def bind(&block); end

  # Whether the computation is complete.
  #
  # @return [Boolean]
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:201
  def complete?; end

  # Maps a successful result to Unit, effectively discards it
  #
  # @return [Task]
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:230
  def discard; end

  # Lifts a block over the Task monad.
  #
  # @param block [Proc]
  # @return [Task]
  # @api public
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:111
  def fmap(&_arg0); end

  # pkg:gem/dry-monads#lib/dry/monads/task.rb:141
  def inspect; end

  # @return [Class]
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:204
  def monad; end

  # Rescues the error with a block that returns another task.
  #
  # @param block [Proc]
  # @return [Object]
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:153
  def or(&block); end

  # Transforms the error if the computation wasn't successful.
  #
  # @param block [Proc]
  # @return [Task]
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:147
  def or_fmap(&_arg0); end

  # pkg:gem/dry-monads#lib/dry/monads/task.rb:122
  def then(*args, &block); end

  # Converts to Maybe. Blocks the current thread if required.
  #
  # @return [Maybe]
  #
  # pkg:gem/dry-monads#lib/dry/monads/maybe.rb:378
  def to_maybe; end

  # Returns self.
  #
  # @return [Maybe::Some, Maybe::None]
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:209
  def to_monad; end

  # Converts to Result. Blocks the current thread if required.
  #
  # @return [Result]
  #
  # pkg:gem/dry-monads#lib/dry/monads/result.rb:397
  def to_result; end

  # @return [String]
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:125
  def to_s; end

  # Retrieves the value of the computation.
  # Blocks current thread if the underlying promise
  # hasn't been complete yet.
  # Throws an error if the computation failed.
  #
  # @return [Object]
  # @api public
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:98
  def value!; end

  # Extracts the resulting value if the computation was successful
  # otherwise yields the block and returns its result.
  #
  # @param block [Proc]
  # @return [Object]
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:177
  def value_or(&_arg0); end

  # Blocks the current thread until the task is complete.
  #
  # @return [Task]
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:182
  def wait(timeout = T.unsafe(nil)); end

  protected

  # @api private
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:83
  def promise; end

  private

  # @api private
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:249
  def compare_promises(x, y); end

  # @api private
  #
  # pkg:gem/dry-monads#lib/dry/monads/task.rb:235
  def curry(value); end

  class << self
    # Creates a Task with the given executor
    #
    # @example providing an executor instance, using Ruby 2.5+ syntax
    #   IO = Concurrent::ThreadPoolExecutor.new
    #   Task[IO] { do_http_request }
    #
    # @example using a predefined executor
    #    Task[:fast] { do_quick_task }
    #
    # @param executor [Concurrent::AbstractExecutorService,Symbol]
    #   Either an executor instance
    #   or a name of predefined global
    #   from concurrent-ruby
    #
    # @return [Task]
    #
    # pkg:gem/dry-monads#lib/dry/monads/task.rb:53
    def [](executor, &_arg1); end

    # Returns a failed task from the given exception
    #
    # @param exc [Exception]
    # @return [Task]
    #
    # pkg:gem/dry-monads#lib/dry/monads/task.rb:76
    def failed(exc); end

    # Creates a Task from a block
    #
    # @overload new(promise)
    #   @param promise [Promise]
    #   @return [Task]
    #
    # @overload new(&block)
    #   @param block [Proc] a task to run
    #   @return [Task]
    #
    # pkg:gem/dry-monads#lib/dry/monads/task.rb:30
    def new(promise = T.unsafe(nil), &_arg1); end

    # Returns a completed task from the given value
    #
    # @overload pure(value)
    #   @param value [Object]
    #   @return [Task]
    #
    # @overload pure(&block)
    #   @param block [Proc]
    #   @return [Task]
    #
    # pkg:gem/dry-monads#lib/dry/monads/task.rb:67
    def pure(value = T.unsafe(nil), &block); end
  end
end

