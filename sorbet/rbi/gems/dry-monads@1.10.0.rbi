  # pkg:gem/dry-monads#lib/dry/monads/maybe.rb:244
  def ==(other); end

  # Pattern matching
  #
  # @example
  #   case Some(:foo)
  #   in Some(Integer)
  #     # ...
  #   in Some(:bar)
  #     # ...
  #   in None()
  #     # ...
  #   end
  #
  # @api private
  #
  # pkg:gem/dry-monads#lib/dry/monads/maybe.rb:262
  def deconstruct; end

  # @api private
  #
  # pkg:gem/dry-monads#lib/dry/monads/maybe.rb:242
  def eql?(other); end

  # @see Maybe::Some#filter
  #
  # @return [Maybe::None]
  #
